<?php

// Include the entity class
module_load_include('inc', 'organization', 'organization.entity');
function organization_menu()
{

    $items = array();

    $items['organization'] = array(
        'title' => t('Organization'),
        'page callback' => 'organization_list_page',
        'access callback' => TRUE,
        'access arguments' => array('view organization'),
    );

    $items['organization/add'] = array(
        'title' => t('Add Organization'),
        'page callback' => 'drupal_get_form',
        'page arguments' => array('organization_form'),
        'access arguments' => array('add organization'),
        'access callback' => 'organization_add_access',
    );

    $items['organization/edit/%'] = array(
        'title' => t('Edit Organization'),
        'page callback' => 'drupal_get_form',
        'page arguments' => array('organization_form', 2),
        'access callback' => 'organization_edit_access',
        'access arguments' => array(2),

    );

    $items['organization/delete/%'] = array(
        'title' => t('Delete Organization'),
        'page callback' => 'organization_delete',
        'page arguments' => array(2),
        'access arguments' => array(2),
        'access callback' => 'organization_delete_access',

    );

    $items['organization/view/%'] = array(
        'title' => t('View Organization'),
        'page callback' => 'organization_view',
        'page arguments' => array(2),
        'access arguments' => array(2),
        'access callback' => 'organization_view_access',

    );

    return $items;
}

/**
 * PERMISSION HOOK
 */
function organization_permission() {
    return array(
        'add organization' => array(
            'title' => t('Add organization'),
        ),
        'edit organization' => array(
            'title' => t('Edit organization'),
        ),
        'delete organization' => array(
            'title' => t('Delete organization'),
        ),
        'view organization' => array(
            'title' => t('View organization'),
        ),
    );
}

function organization_edit_access($id) {
    global $user;

    // Admin can always edit
    if (user_access('administer site configuration')) {
        return TRUE;
    }

    if (user_access('edit organization')) {
        return TRUE;
    }
    // Load the organization
    $organization = organizationController()->loadOrganizationByID($id);
    $wrappedOrganization =entityWrapper($organization);

    if (!$organization) {
        return FALSE;
    }
    // Check if current user owns the organization
    if ($wrappedOrganization['manager_name'] == $user->name) {
        return TRUE;
    }

    return FALSE;
}

function organization_view_access($id) {
    global $user;

    // Admin can always edit
    if (user_access('administer site configuration')) {
        return TRUE;
