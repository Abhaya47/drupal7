function organization_add_access() {
    global $user;

    // Admin can always edit
    if (user_access('administer site configuration')) {
        return TRUE;
    }
    return FALSE;
}

/*
 * Organization Entity definition
 */

function organization_entity_info()
{
    $return['organization'] = array(
        'label' => t('Organization'),
        'base table' => 'organization',
        'controller class' => 'OrganizationAPIController',
        'fieldable' => TRUE,
        'entity keys' => array(
            'id' => 'id',
            'bundle' => 'type',
        ),
        'bundle keys' => array(
            'bundle' => 'type',
        ),
        'bundles' => array(
            'organization' => array(
                'label' => t('Organization'),
            ),
        ),
        'module' => 'organization',
    );

    return $return;
}

function organizationController(): OrganizationAPIController
{
    return new OrganizationAPIController('organization');
}

function entityWrapper($org)
{
    $wrapper = entity_metadata_wrapper('organization', $org);

    $id = NULL;
    if (!empty($wrapper->id->value())) {
        $id = $wrapper->id->value();
    }


    $name = $wrapper->name->value();
    $status = $wrapper->status->value();
    $changed = $wrapper->changed->value();
    $created = $wrapper->created->value();

    // Manager
    $manager_name = '';
    try {
        $manager = $wrapper->field_custom_manager->value();
        if ($manager) {
            $manager_name = $manager->name;
        }
    } catch (Exception $e) {
        $manager_name = '';
    }

    // Phone
    $phone = '';
    try {
        $phone = $wrapper->field_custom_phone->value();
    } catch (Exception $e) {
        $phone = '';
    }

    // Address
    $address = '';
    try {
        $address = $wrapper->field_custom_address->value();
    } catch (Exception $e) {
        $address = '';
    }

    $logo = '';
    try {
        $logo = $wrapper->field_custom_logo->value();
    } catch (Exception $e) {
        $logo = '';
    }

    return array(
        'id' => $id,
        'name' => $name,
        'status' => $status,
        'manager_name' => $manager_name,
        'phone' => $phone,
        'address' => $address,
        'logo' => $logo,
        'changed' => $changed,
        'created' => $created,
    );
}

//main list organizations page
function organization_list_page()
{

    $build['organizations_wrapper'] = array(
        '#type' => 'container',
        '#attributes' => array('id' => 'organizations-wrapper'),
    );

    $header = array(t('Id'), t('Organization Name'), t('Address'), t('Manager'), t('Phone'), t('Operations'));

    $rows = array();

    $params = drupal_get_query_parameters();

    $search = isset($params['search']) ? $params['search'] : '';
    $filter = isset($params['status']) ? $params['status'] : '';

    $filter_form = drupal_get_form('organization_filter_form');


    // loads all organizations
    $organizations = organizationController()->loadOrganization($filter, $search);
    foreach ($organizations as $org) {
        $wrapperResult = entityWrapper($org);

        $links = array();
        $links = array(
            'view' => array(
                'title' => t('View'),
                'href' => 'organization/view/' . $org->id,
            ),
            'edit' => array(
                'title' => t('Edit'),
                'href' => 'organization/edit/' . $org->id,
            ),
            'delete' => array(
                'title' => t('Delete'),
                'href' => 'organization/delete/' . $org->id,
                'attributes' => array(
//                    'class' => array('use-ajax', 'delete-link'),
                    'data-org-id' => $org->id, // optional, can use in JS
                ),
            ),
        );
        // Add row to the table
        $rows[] = array(
            check_plain($org->id),
            check_plain($org->name),
            check_plain($wrapperResult['address']),
            check_plain($wrapperResult['manager_name']),
            check_plain($wrapperResult['phone']),
            $links
        );
    }


    $build['organizations_wrapper']['table'] = array(
        '#theme' => 'organization_list',
        '#header' => $header,
        '#rows' => $rows,
        '#empty' => t('No organizations found'),
        '#filter_form' => $filter_form,
    );


    $build['pager'] = array(
        '#theme' => 'pager',
    );
    $build['#attached']['css'][] = drupal_get_path('module', 'organization') . '/css/organization-list.css';
    return $build;
}


function organization_form($form, &$form_state, $id = NULL)
{
    $organization = NULL;

    if ($id) {
        $organizationEntity = organizationController()->loadOrganizationByID($id);
        $organization = entityWrapper($organizationEntity);
    }

    $form['id'] = array(
        '#type' => 'hidden',
        '#default_value' => $organization ? $organization['id'] : '',);

    $form['name'] = array(
        '#type' => 'textfield',
        '#title' => t('Organization Name'),
        '#required' => TRUE,
        '#default_value' => $organization ? $organization['name'] : '',);

    $form['user'] = array(
        '#type' => 'textfield',
        '#title' => t('User'),
        '#autocomplete_path' => 'user/autocomplete',
        '#description' => t('Start typing the username.'),
        '#default_value' => $organization ? $organization['manager_name'] : '',);

    $form['status'] = array(
        '#type' => 'select',
        '#title' => t('Status'),
        '#options' => array(
            0 => t('Inactive'),
            1 => t('Active'),
        ),
        '#default_value' => $organization ? $organization['status'] : 0,
        '#required' => TRUE,
    );

    $form['address'] = array(
        '#type' => 'textarea',
        '#title' => t('Address'),
        '#default_value' => $organization ? $organization['address'] : '',
        '#required' => TRUE,
    );

    $form['phone'] = array(
        '#type' => 'textfield',
        '#title' => t('Phone'),
        '#default_value' => $organization ? $organization['phone'] : '',
        '#required' => TRUE,
    );

    $form['logo'] = array(
        '#type' => 'managed_file',
        '#title' => t('Logo'),
        '#upload_location' => 'public://organization_logos/',
        '#default_value' => $organization && $organization['logo'] ? array($organization['logo']) : NULL,    );

    $form['submit'] = array(
        '#type' => 'submit',
        '#value' => t('Save Organization'),
    );

    $module_path = drupal_get_path('module', 'organization');

    $form['#attached']['js'][] = array(
        'data' => $module_path . '/js/jquery.validate.min.js',
        'type' => 'file',
        'scope' => 'header',
        'weight' => -20,
    );

    $form['#attached']['js'][] = array(
        'data' => $module_path . '/js/additional-methods.js',
        'type' => 'file',
        'scope' => 'header',
        'weight' => -19,
    );

    $form['#attached']['js'][] = array(
        'data' => $module_path . '/js/organization-form-validate.js',
        'type' => 'file',
        'scope' => 'header',
        'weight' => -18,
    );

    $form['#attributes']['id'] = 'organization-form';
    $form['#theme'] = 'organization_form_template';
    $form['#attached']['css'][] = drupal_get_path('module', 'organization') . '/css/organization-form.css';

    return $form;
}

/**
 * Separate Filter Form Builder
 */
function organization_filter_form($form, &$form_state) {
    $params = drupal_get_query_parameters();
    $form['search'] = array(
        '#type' => 'textfield',
        '#default_value' => isset($params['search']) ? $params['search'] : '',
        '#attributes' => array('placeholder' => t('Search organizations...'), 'id' => 'table-search'),
    );

    $form['status'] = array(
        '#type' => 'select',
        '#options' => array(
            'all' => t('All Status'),
            'active' => t('Active'),
            'inactive' => t('Inactive'),
        ),
        '#default_value' => isset($params['status']) ? $params['status'] : 'all',
        '#attributes' => array('id' => 'status-filter'),
    );

    $form['submit'] = array(
        '#type' => 'submit',
        '#value' => t('Filter'),
    );

    return $form;
}

/**
 * Filter Submit Handler
 */
function organization_filter_form_submit($form, &$form_state) {
    $query = array();
    if (!empty($form_state['values']['search'])) {
        $query['search'] = $form_state['values']['search'];
    }
    if ($form_state['values']['status'] !== 'all') {
        $query['status'] = $form_state['values']['status'];
    }
    // Redirects to current page with ?search=xyz&status=active
    $form_state['redirect'] = array(current_path(), array('query' => $query));
}

function organization_form_validate($form, &$form_state)
{
    if (strlen(trim($form_state['values']['address'])) < 3) {
        form_set_error('address', t('Address must be at least 3 characters long.'));
    }
    if (!isset($form_state['values']['phone']) || !is_numeric($form_state['values']['phone'])) {
        form_set_error('phone', t('Phone must be numeric.'));
    }
}

function organization_form_submit($form, &$form_state) {

    $values = $form_state['values'];
    $lang = LANGUAGE_NONE;
    $id = $values['id'];

    // Load user
    $user = user_load_by_name($values['user']);
    if (empty($user)) {
        form_set_error('user', t('Invalid user selected.'));
        return;
    }


//edit organization
    if (!empty($id)) {

        $organization = organizationController()->loadOrganizationById($id);

        $organization->name = $values['name'];
        $organization->status = $values['status'];
        $organization->field_custom_manager[$lang][0]['target_id'] = $user->uid;
        $organization->field_custom_address[$lang][0]['value'] = $values['address'];
        $organization->field_custom_phone[$lang][0]['value'] = $values['phone'];

        if (!empty($values['logo'])) {

            $fid = is_array($values['logo']) ? $values['logo'][0] : $values['logo'];

            if ($file = file_load($fid)) {

                $file->status = FILE_STATUS_PERMANENT;
                file_save($file);

                $organization->field_custom_logo[$lang][0] = array(
                    'fid' => $values['logo'],
                    'display' => 1,
                    'description' => '',
                );

                file_usage_add($file, 'organization', 'organization', $fid);
            }
        }

        organizationController()->saveOrganization($organization);

        drupal_set_message(t('Organization %name updated.', array('%name' => $organization->name)));

        return;
    }

//create organization

    $controller = entity_get_controller('organization');
    $entity = $controller->create(array('type' => 'organization'));

    $entity->name = $values['name'];
    $entity->status = $values['status'];
    $entity->field_custom_manager[$lang][0]['target_id'] = $user->uid;
    $entity->field_custom_address[$lang][0]['value'] = $values['address'];
    $entity->field_custom_phone[$lang][0]['value'] = $values['phone'];

    // File field handling
    if (!empty($values['logo'])) {

        $fid = is_array($values['logo']) ? $values['logo'][0] : $values['logo'];

        if ($file = file_load($fid)) {

            $file->status = FILE_STATUS_PERMANENT;
            file_save($file);

            $entity->field_custom_logo[$lang][0] = array(
                'fid' => $values['logo'],
                'display' => 1,
                'description' => '',
            );

            file_usage_add($file, 'organization', 'organization', $fid);
        }
    }

    organizationController()->saveOrganization($entity);

    drupal_set_message(t('Organization %name saved.', array('%name' => $entity->name)));
}

function organization_delete($id) {
    organizationController()->deleteOrganization($id);
    drupal_set_message('Organization deleted.');
    drupal_goto('organization/list');
}

function organization_view($id)
{
    $organizationEntity = organizationController()->loadOrganizationByID($id);
    $wrappedOrganization = entityWrapper($organizationEntity);
    drupal_add_css(drupal_get_path('module', 'organization') . '/css/organization-view.css');
    return [
        '#theme' => 'organization_view',
        '#organization' => $wrappedOrganization,
    ];
}

//Theme hook
function organization_theme($existing, $type, $theme, $path)
{
    $result = array(
        'organization_list' => array(
            'variables' => array(
                'header' => NULL,
                'rows' => NULL,
                'empty' => NULL,
                'filter_form' => array(),
            ),
            'template' => 'organization-list',
            'path' => drupal_get_path('module', 'organization') . '/templates',
        ),
        'organization_view' => array(
            'variables' => array(
                'organization' => NULL,
            ),
            'template' => 'organization-view',
            'path' => drupal_get_path('module', 'organization') . '/templates',
        ),
        'organization_form_template' => array(
            'render element' => 'form',
            'template' => 'organization-form',
            'path' => drupal_get_path('module', 'organization') . '/templates',
        ),
    );
    return $result;
}