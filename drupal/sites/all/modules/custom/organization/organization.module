<?php

// Include the entity class
module_load_include('inc', 'organization', 'organization.entity');

function organization_menu()
{

    $items = array();

    $items['organization'] = array(
        'title' => t('Organization'),
        'page callback' => 'organization_list_page',
        'access callback' => TRUE,
        'access arguments' => array('access content'),
    );

    $items['organization/add'] = array(
        'title' => 'Add Organization',
        'page callback' => 'drupal_get_form',
        'page arguments' => array('organization_form'),
        'access arguments' => array('access content'),
    );

    return $items;
}

/*
 * Organization Entity definition
 */

function organization_entity_info() {
    $return['organization'] = array(
        'label' => t('Organization'),
        'base table' => 'organization',
        'controller class' => 'OrganizationAPIController',
        'fieldable' => FALSE,
        'entity keys' => array(
            'id' => 'id',
        ),
        'bundles' => array(
            'organization' => array(
                'label' => t('Organization'),
            ),
        ),
        'module' => 'organization',
    );

    return $return;
}

function organization_load() {
    $controller = new OrganizationAPIController('organization');
    return $controller->organization_load();
}

function organization_list_page()
{
    $header = array(t('Id'), t('Organization Name'), t('Location'), t('Manager'), t('Phone'));

    $rows = array();
    // loads all organizations
    $organizations = organization_load();
    foreach ($organizations as $row) {

        // Location
//        $location_id = isset($org->field_location['und'][0]['target_id']) ? $org->field_location['und'][0]['target_id'] : NULL;
        $location_name = '';
//        if ($location_id) {
////            $location_entity = entity_load('location', array($location_id));
//            $location_name = '$location_entity[$location_id]->name;'
//        }

        // Manager
        $manager_id = isset($org->field_manager['und'][0]['target_id']) ? $org->field_manager['und'][0]['target_id'] : NULL;
        if ($manager_id) {
            $manager_name = user_load($manager_id)->name;
        }

        // Phone
        $phone = isset($org->field_phone['und'][0]['value']) ? $org->field_phone['und'][0]['value'] : '';

        // Define operations (Edit and Delete links)
        $operations = l(t('Edit'), 'organization/edit/' . $row->id) . ' | ';
        $operations .= l(t('Delete'), 'organization/delete/' . $row->id);

        // Add row to the table
        $rows[] = array(
            $row->id,
            $row->name,
            $location_name,
            $manager_name,
            $row,
            $operations
        );
    }

    return theme('table', array(
        'header' => $header,
        'rows' => $rows,
    ));
}

function organization_form($form, &$form_state)
{

    $form['name'] = array(
        '#type' => 'textfield',
        '#title' => 'Organization Name',
        '#required' => TRUE,
    );

    // Location dropdown


    $form['address'] = array(
        '#type' => 'textarea',
        '#title' => 'Address',
    );

    $form['phone'] = array(
        '#type' => 'textfield',
        '#title' => 'Phone',
    );

    $form['logo'] = array(
        '#type' => 'managed_file',
        '#title' => 'Logo',
        '#upload_location' => 'public://organization_logos/',
    );

    $form['submit'] = array(
        '#type' => 'submit',
        '#value' => 'Save Organization',
    );

    return $form;
}

