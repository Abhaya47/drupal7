<?php

class OrganizationAdminTestCase extends DrupalWebTestCase
{

    public static function getInfo()
    {
        return array(
            'name' => 'Organization Form Test',
            'description' => 'Comprehensive test for Organization form.',
            'group' => 'Organization',
        );
    }

    public function setUp()
    {
        global $base_url;
        $base_url = 'http://localhost';
        // 1. parent::setUp takes an array of modules and enables them properly.
        parent::setUp(array('organization', 'user', 'entity'));

        // 2. Explicitly define only the permissions needed.
        // This is much safer than dynamically invoking all permissions.
        // 'administer organization', <- Add your custom module's permissions here
        $permissions = array(
            'access content',
            'access administration pages',
            'administer site configuration'
        );

        $this->admin_user = $this->drupalCreateUser($permissions);

        // 3. Robust check
        if (!$this->admin_user) {
            $this->fail('User creation failed!');
            return;
        }

        // 4. Log in
        $edit = array(
            'name' => $this->admin_user->name,
            'pass' => $this->admin_user->pass_raw,
        );
        $this->drupalPost('user/login', $edit, t('Log in'));

// Verify we are actually logged in by checking the $user object in the test environment
        $this->assertTrue($this->admin_user->uid > 0, 'User is logged in successfully.');
    }

    public function testAdminFormFlow()
    {
        global $base_url;
        $base_url = 'http://localhost';


        // 3. Navigate to the form
        $path = 'organization/add';
        $this->drupalGet($path);

        // 4. STOP if the page is empty to prevent DOMDocument error
        $content = $this->drupalGetContent();
//        to debug the code
//        debug($content, 'Dump of page content');
        if (empty($content)) {
            $this->fail('The page at ' . $path . ' returned no content (White Screen of Death).');
            return;
        }

        $this->assertResponse(200);
        // 5. Submit with an admin user
        $edit = array(
            'name' => 'Test Corp',
            'status' => 1,
            'address' => 'Kathmandu',
            'phone' => '9800000000',
        );

        $this->drupalPost(NULL, $edit, t('Save Organization'));

        // 6. Check for the specific success message in your code
        $this->assertText('Test Corp');
    }
}