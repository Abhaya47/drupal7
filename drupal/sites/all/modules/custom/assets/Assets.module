<?php


function assets_menu()
{
    $items = [];

    $items['assets'] = [
        'title' => 'Assets',
        'page callback' => 'assets_page',
        'access callback' => TRUE,
    ];

    return $items;
}

function assets_page() {

    $assets = getassets();

    if (empty($assets)) {
        return '<p>No assets found.</p>';
    }

    return "$assets";
}


